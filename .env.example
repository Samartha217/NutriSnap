# Required — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required — get from https://console.groq.com (free, works in India)
GROQ_API_KEY=your_groq_api_key_here

# Optional — Gemini (may not work in India on free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Required — get from https://fdc.nal.usda.gov/api-key-signup (free)
USDA_API_KEY=your_usda_api_key_here

# Deployment — set to your Render URL after first deploy
WEBHOOK_URL=https://nutrisnap.onrender.com

# Optional
PORT=8000
LOG_LEVEL=INFO
MAX_IMAGE_SIZE_MB=5
RATE_LIMIT_REQUESTS_PER_MINUTE=3
